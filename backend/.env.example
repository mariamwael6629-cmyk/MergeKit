# Copy this file to .env and adjust values as needed.

# Database connection string (SQLAlchemy URL). Defaults to a local SQLite file.
DATABASE_URL=sqlite:///./mergekit.db

# JWT auth
SECRET_KEY=change-this-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated list of origins allowed to call the API
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,http://localhost:8080

# Demo account auto-provisioned on startup so the frontend has data to show
DEMO_USER_EMAIL=demo@mergekit.dev
DEMO_USER_PASSWORD=demo1234
